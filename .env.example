# =============================================================================
# FinalBoss.io — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in values for your deployment.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# -----------------------------------------------------------------------------
# REQUIRED — Core site identity
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=https://finalboss.io
NEXT_PUBLIC_WORDPRESS_URL=https://backend.finalboss.io

# -----------------------------------------------------------------------------
# OPTIONAL — Site branding (defaults to finalboss.io values)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_NAME=FinalBoss.io
# NEXT_PUBLIC_LOCALE=en                          # "en" or "fr"
# NEXT_PUBLIC_TAGLINE=Your Ultimate Gaming Destination
# NEXT_PUBLIC_SITE_DESCRIPTION=Discover the latest gaming news, reviews, guides, and technology insights.
# NEXT_PUBLIC_LOGO_PATH=/finalboss.png
# NEXT_PUBLIC_OG_IMAGE_PATH=/images/finalboss-og-image.jpg

# -----------------------------------------------------------------------------
# OPTIONAL — Analytics & Ads
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GA_ID=G-HV2MVVJDN4
# NEXT_PUBLIC_SITE_VERIFICATION=e2c216ee3e6ae9705e843d5a227568c93d21a3ac
# NEXT_PUBLIC_ADSENSE_PUB_ID=ca-pub-7494322760704385

# --- Ezoic Ads ---
# Set to "true" after Ezoic account is approved and placeholders are configured
# NEXT_PUBLIC_ENABLE_EZOIC=false
# Comma-separated list of ALL placeholder IDs used on the site
# NEXT_PUBLIC_EZOIC_PLACEHOLDER_IDS=101,102,103,104,105,106,107
# Individual slot IDs (create these in the Ezoic dashboard)
# NEXT_PUBLIC_EZOIC_SLOT_ARTICLE_TOP=101
# NEXT_PUBLIC_EZOIC_SLOT_ARTICLE_CONTENT=102
# NEXT_PUBLIC_EZOIC_SLOT_ARTICLE_BOTTOM=103
# NEXT_PUBLIC_EZOIC_SLOT_SIDEBAR_LEFT=104
# NEXT_PUBLIC_EZOIC_SLOT_SIDEBAR_RIGHT=105
# NEXT_PUBLIC_EZOIC_SLOT_REVIEWS_HEADER=106
# NEXT_PUBLIC_EZOIC_SLOT_REVIEWS_GRID=107

# -----------------------------------------------------------------------------
# OPTIONAL — Forms
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_FORMSPREE_ID=xjkronpd

# -----------------------------------------------------------------------------
# OPTIONAL — Contact
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_CONTACT_EMAIL=thebosses@finalboss.io

# -----------------------------------------------------------------------------
# OPTIONAL — Social links
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_TWITTER_HANDLE=@finalbossio
# NEXT_PUBLIC_TWITTER_URL=https://x.com/FinalBoss_io
# NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/FinalBoss.io/
# NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/finalboss.io/
# NEXT_PUBLIC_YOUTUBE_URL=https://www.youtube.com/@finalboss6969

# -----------------------------------------------------------------------------
# OPTIONAL — YouTube integration
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_YOUTUBE_CHANNEL_ID=UCFinalboss6969
# NEXT_PUBLIC_YOUTUBE_API_KEY=

# -----------------------------------------------------------------------------
# Server-side only — WordPress
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_WORDPRESS_API_URL=https://backend.finalboss.io/graphql
# NEXT_PUBLIC_WP_NONCE=

# -----------------------------------------------------------------------------
# REQUIRED — IGDB / Twitch credentials (server-side only)
# The Next.js app talks directly to the IGDB API via Twitch OAuth2.
# Get credentials at https://dev.twitch.tv/console/apps
# -----------------------------------------------------------------------------
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
